---
const items = [
  {
    tag: 'Wakaf',
    title: 'Mushaf Orang Tua',
    desc: "Mushaf Al-Qur'an khusus untuk orang tua dengan ukuran huruf yang lapang dan nyaman dibaca, didistribusikan ke masjid dan majelis sepuh.",
    src: '/program-mushaf-orangtua.jpg',
  },
  {
    tag: 'Wakaf',
    title: 'Mushaf Pelosok',
    desc: "Distribusi mushaf ke desa-desa pelosok, TPQ, dan pesantren yang masih sangat membutuhkan akses Al-Qur'an untuk pembelajaran harian.",
    src: '/program-mushaf-pelosok.jpg',
  },
  {
    tag: 'Tebusan',
    title: 'Kafarat',
    desc: 'Penyaluran kafarat sesuai syariat — langsung kepada fakir miskin, dengan pendampingan dan dokumentasi proses sampai diterima.',
    src: '/program-kafarat.jpg',
  },
];
---

<section class="section-pad" id="program">
  <div class="container">
    <div class="programs-head">
      <div data-reveal>
        <div class="eyebrow"><span class="section-num">03 / Program Donasi</span></div>
        <h2 class="display">
          Pilih amal terbaik<br/>yang ingin Anda <em>titipkan</em>.
        </h2>
      </div>
      <p class="lede" data-reveal>
        Setiap program di bawah ini bukan sekadar pilihan amal, tapi jawaban bagi mereka yang sedang menunggu bantuan hari ini.
      </p>
    </div>
    <div class="programs-grid">
      {items.map((p) => (
        <article class="program-card" data-reveal>
          <div class="program-img">
            <img src={p.src} alt={p.title} loading="lazy" width="800" height="600" />
            <span class="program-tag">{p.tag}</span>
          </div>
          <div class="program-body">
            <h3>{p.title}</h3>
            <p>{p.desc}</p>
            <a href="#donor" class="program-cta">
              Titipkan amanah <span class="arrow"><svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
